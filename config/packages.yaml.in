packages:
  adios2:
    require: "+hdf5"
  binutils:
    # LLVM depends on binutils with these variants
    require: "+gold+headers+ld+plugins"
  boost:
    # Valgrind depends on Boost with these variants
    require: "+atomic+chrono+exception+system+thread"
  cairo:
    require: "+gobject+X"
  cuda:
    require: "@@BOOTSTRAP_CONFIG_CUDA@"
  curl:
    require: "+libidn2+nghttp2"
  doxygen:
    require: "+graphviz"
  environment-modules:
    require: "target=x86_64"
  ffmpeg:
    require: "+libaom+libmp3lame+libopenjpeg+libopus+libspeex+libvorbis+libvpx+libwebp+libx264+nonfree"
  gl:
    require: "osmesa"
  gnuplot:
    require: "+X"
  graphviz:
    require: "+libgd+pangocairo+poppler"
  hdf5:
    require: "+hl+szip+threadsafe"
  libfabric:
    require: "fabrics=sockets,tcp,udp,verbs,rxd,rxm"
  libfuse:
    # FIXME Check whether this needs to be the same version as the system FUSE
    require: "~utils"
  mbedtls:
    require: "libs=shared,static"
  mpi:
    require: "mpich"
  mpich:
    require: "device=ch4 netmod=ofi"
  octave:
    # FIXME +gl2ps+opengl+qscintilla+qt
    require: "+arpack+fftw+fontconfig+freetype+gnuplot+hdf5+llvm+qrupdate+readline+suitesparse"
  pango:
    require: "+X"
  pcre:
    require: "+jit"
  postgresql:
    require: "+client_only+threadsafe"
  py-matplotlib:
    require: "backend=qt5agg"
  py-torch:
    require: "+cuda cuda_arch=80,86,90,90a"
  qt:
    require: "+opengl"
  qt-base:
    require: "+opengl"
  vim:
    require: "features=huge +python"
  zstd:
    require: "+programs"
  all:
    # Make sure to build for a generic architecture
    target: [x86_64_v3]
